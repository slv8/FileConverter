{
  "openapi": "3.1.0",
  "info": {
    "title": "FastAPI",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/conversions/start": {
      "post": {
        "summary": "Start Conversion",
        "description": "Initiates a file conversion using file ID and target extension. Returns a conversion object.",
        "operationId": "start_conversion_api_v1_conversions_start_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartConversionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartConversionResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/conversions/{conversion_id}": {
      "get": {
        "summary": "Get Conversion",
        "description": "Retrieve the information of a specific conversion by its ID.",
        "operationId": "get_conversion_api_v1_conversions__conversion_id__get",
        "parameters": [
          {
            "name": "conversion_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Conversion Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetConversionResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/conversions/": {
      "get": {
        "summary": "Get Conversions",
        "description": "Retrieve a list of all file conversions with their current information.",
        "operationId": "get_conversions_api_v1_conversions__get",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/ConversionStatus"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Status"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/FileOutputExtension"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Format"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 1000,
              "exclusiveMinimum": 0,
              "default": 100,
              "title": "Limit"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "title": "Offset"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetConversionsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/files/upload": {
      "post": {
        "summary": "Upload File",
        "description": "Upload a file for conversion. Returns a file ID that can be used to start a conversion later.",
        "operationId": "upload_file_api_v1_files_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_file_api_v1_files_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadFileResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/files/{file_id}/download": {
      "get": {
        "summary": "Download File",
        "description": "Download the converted or original file by its file ID.",
        "operationId": "download_file_api_v1_files__file_id__download_get",
        "parameters": [
          {
            "name": "file_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "File Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/octet-stream": {

              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Body_upload_file_api_v1_files_upload_post": {
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_upload_file_api_v1_files_upload_post"
      },
      "ConversionStatus": {
        "type": "string",
        "enum": [
          "pending",
          "in_progress",
          "completed",
          "failed"
        ],
        "title": "ConversionStatus"
      },
      "FileOutputExtension": {
        "type": "string",
        "enum": [
          "pdfx",
          "jsonl",
          "binx"
        ],
        "title": "FileOutputExtension"
      },
      "GetConversionResponse": {
        "properties": {
          "timestamp": {
            "type": "integer",
            "title": "Timestamp"
          },
          "data": {
            "$ref": "#/components/schemas/PublicConversion"
          }
        },
        "type": "object",
        "required": [
          "data"
        ],
        "title": "GetConversionResponse"
      },
      "GetConversionsResponse": {
        "properties": {
          "timestamp": {
            "type": "integer",
            "title": "Timestamp"
          },
          "data": {
            "items": {
              "$ref": "#/components/schemas/PublicConversion"
            },
            "type": "array",
            "title": "Data"
          }
        },
        "type": "object",
        "required": [
          "data"
        ],
        "title": "GetConversionsResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PublicConversion": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id",
            "description": "Unique identifier of the conversion"
          },
          "status": {
            "$ref": "#/components/schemas/ConversionStatus",
            "description": "Current status of the conversion process"
          },
          "progress": {
            "type": "integer",
            "title": "Progress",
            "description": "Progress percentage (0 to 100) of the conversion"
          },
          "originalFileUrl": {
            "type": "string",
            "maxLength": 2083,
            "minLength": 1,
            "format": "uri",
            "title": "Originalfileurl",
            "description": "Public URL to access the original uploaded file"
          },
          "convertedFileUrl": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 2083,
                "minLength": 1,
                "format": "uri"
              },
              {
                "type": "null"
              }
            ],
            "title": "Convertedfileurl",
            "description": "Public URL to access the converted file (if available)"
          }
        },
        "type": "object",
        "required": [
          "id",
          "status",
          "progress",
          "originalFileUrl"
        ],
        "title": "PublicConversion"
      },
      "StartConversionRequest": {
        "properties": {
          "fileId": {
            "type": "string",
            "format": "uuid",
            "title": "Fileid",
            "description": "Unique identifier of the file"
          },
          "extension": {
            "$ref": "#/components/schemas/FileOutputExtension",
            "description": "Target file extension"
          }
        },
        "type": "object",
        "required": [
          "fileId",
          "extension"
        ],
        "title": "StartConversionRequest"
      },
      "StartConversionResponse": {
        "properties": {
          "timestamp": {
            "type": "integer",
            "title": "Timestamp"
          },
          "data": {
            "$ref": "#/components/schemas/PublicConversion"
          }
        },
        "type": "object",
        "required": [
          "data"
        ],
        "title": "StartConversionResponse"
      },
      "UploadFileResponse": {
        "properties": {
          "timestamp": {
            "type": "integer",
            "title": "Timestamp"
          },
          "data": {
            "$ref": "#/components/schemas/UploadFileResponseData"
          }
        },
        "type": "object",
        "required": [
          "data"
        ],
        "title": "UploadFileResponse"
      },
      "UploadFileResponseData": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id",
            "description": "Unique identifier of the file"
          }
        },
        "type": "object",
        "required": [
          "id"
        ],
        "title": "UploadFileResponseData"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}